{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "donpdf",
    "compatibility_date": "2025-09-27",
    "observability": {
        "enabled": true
    },
    "assets": {
        "not_found_handling": "single-page-application",
        "exclude": [
            "_redirects"
        ]
    },
    "compatibility_flags": [
        "nodejs_compat"
    ]
}